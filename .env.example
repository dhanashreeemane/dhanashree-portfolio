# ─────────────────────────────────────────────────────────────────────────
#  Environment variables — copy this file to .env.local and fill in real
#  values for the features that need a backend. The site builds and runs
#  fine without any of these; they only light up specific integrations.
# ─────────────────────────────────────────────────────────────────────────

# Contact form (src/components/sections/ContactForm.tsx posts to /api/contact,
# which does not exist yet — create it and use one of these to send mail).
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# AI chat widget (src/components/ui/ChatWidget.tsx — currently returns a
# stub reply). Create /api/chat and call the Anthropic API server-side.
ANTHROPIC_API_KEY=

# GitHub stats panel (src/components/sections/GithubStats.tsx) works without
# a token via the public API, but is rate-limited to 60 requests/hour per IP.
# Add a token and proxy through /api/github for production traffic.
GITHUB_TOKEN=

# Site URL, used in metadata/sitemap (src/data/profile.ts -> siteMeta.url)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
